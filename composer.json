{
    "name": "marko/database-readwrite",
    "description": "Read/write connection splitting for the Marko Framework database layer",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.5",
        "ext-pdo": "*",
        "marko/core": "self.version",
        "marko/database": "self.version"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Database\\ReadWrite\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Database\\ReadWrite\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
